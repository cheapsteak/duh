# --------------- HTTP handler -----------------------------------------------

class _DuhHandler(BaseHTTPRequestHandler):
    """Handles all HTTP requests for the duh serve UI."""

    # These are set as class attributes by cmd_serve before the server starts
    db_path: str = ""
    dir_agg: dict = {}
    path_cache: "_PathCache | None" = None
    freeable_map: dict = {}
    locked_here_map: dict = {}
    _con_local = threading.local()  # per-thread DB connections

    def log_message(self, fmt, *args):
        # Suppress default access log; print to stderr cleanly
        print(f"[serve] {self.address_string()} {fmt % args}", file=sys.stderr)

    def _get_con(self) -> sqlite3.Connection:
        """Return a per-thread read-only connection."""
        con = getattr(self._con_local, "con", None)
        if con is None:
            con = sqlite3.connect(self.db_path)
            con.row_factory = sqlite3.Row
            con.execute("PRAGMA query_only = 1")
            con.execute("PRAGMA cache_size = -262144")
            self._con_local.con = con
        return con

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        path = parsed.path.rstrip("/") or "/"

        try:
            if path == "/" or path == "/index.html":
                self._serve_html()
            elif path == "/api/root":
                self._api_root()
            elif path.startswith("/api/node/"):
                node_id = int(path[len("/api/node/"):])
                self._api_node(node_id)
            elif path.startswith("/api/marginal/"):
                node_id = int(path[len("/api/marginal/"):])
                self._api_marginal(node_id)
            elif path.startswith("/api/breadcrumb/"):
                node_id = int(path[len("/api/breadcrumb/"):])
                self._api_breadcrumb(node_id)
            else:
                self._send_json({"error": "not found"}, status=404)
        except ValueError:
            self._send_json({"error": "invalid id"}, status=400)
        except Exception as e:
            self._send_json({"error": str(e)}, status=500)

    def _serve_html(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(_HTML_BYTES)))
        self.end_headers()
        self.wfile.write(_HTML_BYTES)

    def _api_root(self):
        con = self._get_con()
        scan = con.execute(
            "SELECT root FROM scans ORDER BY id DESC LIMIT 1"
        ).fetchone()
        if not scan:
            self._send_json({"error": "no scans"}, status=404)
            return
        root_path = scan["root"]
        row = con.execute(
            "SELECT id FROM files WHERE parent_id IS NULL AND name = ?",
            (root_path,),
        ).fetchone()
        if not row:
            self._send_json({"error": "root node not found"}, status=404)
            return
        self._send_json({
            "id": row["id"],
            "path": root_path,
            "name": root_path,
        })

    def _api_node(self, node_id: int):
        con = self._get_con()
        node_row = con.execute(
            "SELECT id, parent_id, name, is_dir, is_excluded FROM files WHERE id = ?",
            (node_id,),
        ).fetchone()
        if not node_row:
            self._send_json({"error": "not found"}, status=404)
            return

        agg = self.dir_agg.get(node_id, {})
        node_path = self.path_cache.get(node_id)

        node_info = {
            "id": node_id,
            "path": node_path,
            "name": node_row["name"],
            "is_dir": node_row["is_dir"],
            "is_excluded": node_row["is_excluded"],
            "total_blocks": agg.get("total_blocks", 0),
            "total_logical": agg.get("total_logical", 0),
            "total_files": agg.get("total_files", 0),
            "parent_id": node_row["parent_id"],
            "freeable": self.freeable_map.get(node_id, 0),
            "locked_here": self.locked_here_map.get(node_id, 0),
        }

        # Fetch immediate children
        child_rows = con.execute(
            "SELECT id, name, is_dir, is_excluded, size_blocks, size_logical, "
            "       excluded_file_count "
            "FROM files WHERE parent_id = ?",
            (node_id,),
        ).fetchall()

        children = []
        for cr in child_rows:
            cid = cr["id"]
            if cr["is_dir"] and not cr["is_excluded"]:
                cagg = self.dir_agg.get(cid, {})
                total_blocks = cagg.get("total_blocks", 0)
                total_logical = cagg.get("total_logical", 0)
                total_files = cagg.get("total_files", 0)
            elif cr["is_excluded"]:
                total_blocks = cr["size_blocks"]
                total_logical = cr["size_logical"]
                total_files = cr["excluded_file_count"] or 0
            else:
                # Regular file
                total_blocks = cr["size_blocks"]
                total_logical = cr["size_logical"]
                total_files = 1

            children.append({
                "id": cid,
                "name": cr["name"],
                "is_dir": cr["is_dir"],
                "is_excluded": cr["is_excluded"],
                "total_blocks": total_blocks,
                "total_logical": total_logical,
                "total_files": total_files,
                "freeable": self.freeable_map.get(cid, 0),
                "locked_here": self.locked_here_map.get(cid, 0),
            })

        # Sort by freeable desc by default, limit 200
        children.sort(key=lambda x: x["freeable"], reverse=True)
        children = children[:200]

        self._send_json({"node": node_info, "children": children})

    def _api_marginal(self, node_id: int):
        con = self._get_con()
        row = con.execute("SELECT id FROM files WHERE id = ?", (node_id,)).fetchone()
        if not row:
            self._send_json({"error": "not found"}, status=404)
            return
        result = _marginal_for_id(con, node_id)
        self._send_json(result)

    def _api_breadcrumb(self, node_id: int):
        con = self._get_con()
        # Walk up via recursive CTE
        rows = con.execute("""
          WITH RECURSIVE chain(id, parent_id, name) AS (
            SELECT id, parent_id, name FROM files WHERE id = ?
            UNION ALL
            SELECT f.id, f.parent_id, f.name FROM files f, chain c WHERE f.id = c.parent_id
          )
          SELECT id, name FROM chain
        """, (node_id,)).fetchall()
        crumbs = [{"id": r["id"], "name": r["name"]} for r in rows]
        crumbs.reverse()
        self._send_json(crumbs)

    def _send_json(self, data, status: int = 200):
        body = json.dumps(data).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


# --------------- main cmd_serve ---------------------------------------------

def cmd_serve(args: argparse.Namespace) -> None:
    con = open_db_for_read()
    _init_schema(con)

    # Pre-compute directory aggregates
    dir_agg = _build_dir_agg(con)

    # Pre-compute freeable metrics
    freeable_map, locked_here_map = compute_freeable(con)

    # Path cache (shared across threads, thread-safe, uses per-thread connections)
    path_cache = _PathCache(DB_PATH)

    # Set class-level state on handler (safe: single server, class used as singleton)
    _DuhHandler.db_path = DB_PATH
    _DuhHandler.dir_agg = dir_agg
    _DuhHandler.path_cache = path_cache
    _DuhHandler.freeable_map = freeable_map
    _DuhHandler.locked_here_map = locked_here_map

    # Find an available port
    port = args.port
    max_port = args.port + 10
    server = None
    while port < max_port:
        try:
            server = ThreadingHTTPServer(("127.0.0.1", port), _DuhHandler)
            break
        except OSError:
            port += 1
    if server is None:
        sys.exit(f"error: could not bind to any port in range {args.port}–{max_port - 1}")

    url = f"http://127.0.0.1:{port}/"
    print(f"[serve] listening on {url}", file=sys.stderr)
    print(url)  # stdout for scripts

    # Open browser unless suppressed
    if not args.no_browser:
        subprocess.Popen(["open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def _handle_sigint(sig, frame):
        print("\n[serve] shutting down...", file=sys.stderr)
        threading.Thread(target=server.shutdown, daemon=True).start()

    signal.signal(signal.SIGINT, _handle_sigint)

    try:
        server.serve_forever()
    except Exception:
        pass
    print("[serve] done.", file=sys.stderr)


# ---------------------------------------------------------------------------
# CLUSTERS subcommand
# ---------------------------------------------------------------------------
def cmd_clusters(args: argparse.Namespace) -> None:
    """Report directories with largest locked_here (families spanning multiple children)."""
    con = open_db_for_read()
    _init_schema(con)

    min_bytes = args.min_bytes
    limit = args.limit

    freeable_map, locked_here_map = compute_freeable(con)

    # Sort by locked_here descending
    ranked = sorted(locked_here_map.items(), key=lambda x: x[1], reverse=True)
    ranked = [(nid, v) for nid, v in ranked if v >= min_bytes][:limit]

    if not ranked:
        print("(no clusters found)")
        return

    home = os.path.expanduser("~")

    if args.json:
        out = []
        for nid, locked in ranked:
            path = full_path(con, nid).replace(home, "~")
            out.append({"path": path, "locked_bytes": locked})
        print(json.dumps(out, indent=2))
        return

    for nid, locked in ranked:
        path = full_path(con, nid).replace(home, "~")
        children = con.execute(
            "SELECT id, name FROM files WHERE parent_id = ?", (nid,)
        ).fetchall()
        n_children = len(children)
        print(f"{fmt_bytes(locked)} locked at {path}  (members span ~{n_children} children)")
        # Show top contributing children by freeable
        child_freeable = [(c["name"], freeable_map.get(c["id"], 0)) for c in children]
        child_freeable.sort(key=lambda x: x[1], reverse=True)
        top6 = child_freeable[:6]
        shown = 0
        for name, fb in top6:
            if fb > 0:
                print(f"    members in: {name}")
                shown += 1
        rest = n_children - shown
        if rest > 0:
            print(f"    +{rest} more")
        print()


