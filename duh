def cmd_selftest(_args: argparse.Namespace) -> None:
    """Verify APFS clone detection via a real clone/copy test."""
    import shutil
    print("Running clone-detection self-test...")

    home_tmp = os.path.join(os.path.expanduser("~"), "tmp-duh-selftest")
    os.makedirs(home_tmp, exist_ok=True)
    import time as _time
    tmpdir = os.path.join(home_tmp, f"run-{int(_time.time() * 1000)}")
    os.makedirs(tmpdir)
    src   = os.path.join(tmpdir, "src")
    clone = os.path.join(tmpdir, "clone")
    copy  = os.path.join(tmpdir, "copy")

    try:
        with open(src, "wb") as f:
            f.write(os.urandom(1 * 1024 * 1024))

        ret = os.system(f"cp -c {src!r} {clone!r} 2>/dev/null")
        if ret != 0:
            print("  warning: cp -c returned non-zero (not on APFS?)")

        shutil.copy2(src, copy)

        src_id   = get_clone_id(src)
        clone_id = get_clone_id(clone)
        copy_id  = get_clone_id(copy)

        print(f"  src   clone_id = {src_id}")
        print(f"  clone clone_id = {clone_id}")
        print(f"  copy  clone_id = {copy_id}")

        ok_clone = (src_id is not None) and (src_id == clone_id)
        ok_copy  = (copy_id is None) or (copy_id != src_id)

        if ok_clone and ok_copy:
            print("  PASS: src and clone share clone_id; copy has different clone_id")
        elif not ok_clone:
            print("  FAIL: src and clone do NOT share clone_id — ctypes plumbing issue")
            sys.exit(1)
        else:
            print(f"  WARN: copy has same clone_id as src ({copy_id}) — unexpected")

    finally:
        shutil.rmtree(tmpdir, ignore_errors=True)
        try:
            os.rmdir(home_tmp)
        except OSError:
            pass


# ---------------------------------------------------------------------------
# IEC formatting helpers
# ---------------------------------------------------------------------------
def fmt_bytes(n: int) -> str:
    if n < 0:
        return f"-{fmt_bytes(-n)}"
    for unit, threshold in (("GiB", 1 << 30), ("MiB", 1 << 20), ("KiB", 1 << 10)):
        if n >= threshold:
            return f"{n / threshold:.1f} {unit}"
    return f"{n} B"


def fmt_bytes_highlight(real: int, apparent: int) -> str:
    s = fmt_bytes(apparent)
    if real > 0 and abs(apparent - real) / real > 0.05:
        return f"({s})"
    return s


def col_width(items: list[str], header: str) -> int:
    return max(len(header), *(len(s) for s in items)) if items else len(header)


