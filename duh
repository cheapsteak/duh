# ---------------------------------------------------------------------------
# getattrlist ctypes binding (unchanged from v1)
# ---------------------------------------------------------------------------
ATTR_BIT_MAP_COUNT       = 5
ATTR_CMN_RETURNED_ATTRS  = 0x80000000
ATTR_CMNEXT_CLONEID      = 0x00000100  # NOTE: spec says 0x40 but actual value is 0x100
FSOPT_NOFOLLOW           = 0x00000001
FSOPT_PACK_INVAL_ATTRS   = 0x00000008
FSOPT_ATTR_CMN_EXTENDED  = 0x00000020

_ATTRLIST_FMT = "HHIIIIi"
_ATTRLIST_SIZE = struct.calcsize(_ATTRLIST_FMT)  # should be 24
_BUF_SIZE = 64

try:
    _libc = ctypes.CDLL(ctypes.util.find_library("System"), use_errno=True)
    _getattrlist = _libc.getattrlist
    _getattrlist.restype = ctypes.c_int
    _getattrlist.argtypes = [
        ctypes.c_char_p,
        ctypes.c_void_p,
        ctypes.c_void_p,
        ctypes.c_size_t,
        ctypes.c_ulong,
    ]
    _GETATTRLIST_OK = True
except Exception:
    _GETATTRLIST_OK = False


def get_clone_id(path: str) -> int | None:
    """Return APFS clone ID for path, or None if unavailable/unsupported."""
    if not _GETATTRLIST_OK:
        return None

    attrlist_buf = struct.pack(
        _ATTRLIST_FMT,
        ATTR_BIT_MAP_COUNT,
        0,
        ATTR_CMN_RETURNED_ATTRS,
        0,
        0,
        0,
        ATTR_CMNEXT_CLONEID,
    )
    attrlist_c = ctypes.create_string_buffer(attrlist_buf)
    out_buf = ctypes.create_string_buffer(_BUF_SIZE)
    options = ctypes.c_ulong(FSOPT_NOFOLLOW | FSOPT_PACK_INVAL_ATTRS | FSOPT_ATTR_CMN_EXTENDED)

    ret = _getattrlist(
        path.encode("utf-8", errors="surrogateescape"),
        attrlist_c,
        out_buf,
        ctypes.c_size_t(_BUF_SIZE),
        options,
    )
    if ret != 0:
        return None

    raw = bytes(out_buf)
    total_len = struct.unpack_from("<I", raw, 0)[0]
    if total_len < 32:
        return None

    returned_forkattr = struct.unpack_from("<I", raw, 20)[0]
    if not (returned_forkattr & ATTR_CMNEXT_CLONEID):
        return None

    clone_id = struct.unpack_from("<Q", raw, 24)[0]
    if clone_id == 0:
        return None
    return clone_id


# ---------------------------------------------------------------------------
# Verification test for ctypes binding (unchanged from v1)
