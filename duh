# ---------------------------------------------------------------------------
def cmd_top(args: argparse.Namespace) -> None:
    con = open_db_for_read()
    _init_schema(con)

    under = args.under
    depth = args.depth
    limit = args.limit
    by = args.by

    if under:
        under = os.path.realpath(under)
        root_id = resolve_path_to_id(con, under)
        if root_id is None:
            sys.exit(f"error: path not found in DB: {under}\nRun `duh scan` first.")
    else:
        scan = con.execute("SELECT root FROM scans ORDER BY id DESC LIMIT 1").fetchone()
        if not scan:
            sys.exit("error: no scans found. Run `duh scan <path>` first.")
        under = scan["root"]
        root_id = resolve_path_to_id(con, under)
        if root_id is None:
            sys.exit(f"error: root not found in DB: {under}")

    # Strategy: Two-phase approach.
    # Phase 1: Find bucket nodes = direct descendants at exactly `depth` levels from root,
    #          OR shallower nodes that are leaves (no children) or excluded dirs.
    # Phase 2: For each bucket, sum all descendant file sizes.
    #
    # We use a recursive CTE that:
    #   - Propagates bucket_id (frozen at depth from root)
    #   - Recurses to all leaves (no depth cap on recursion)
    #   - Skips further recursion into excluded dirs (they're aggregates)
    sql = """
    WITH RECURSIVE
    tree(id, is_dir, is_excluded, size_blocks, size_logical, clone_id,
         excluded_file_count, cur_depth, bucket_id) AS (
      -- Seed: direct children of root_id at depth=1
      SELECT f.id, f.is_dir, f.is_excluded,
             f.size_blocks, f.size_logical, f.clone_id, f.excluded_file_count,
             1 AS cur_depth,
             f.id AS bucket_id
      FROM files f WHERE f.parent_id = :root_id
      UNION ALL
      SELECT f.id, f.is_dir, f.is_excluded,
             f.size_blocks, f.size_logical, f.clone_id, f.excluded_file_count,
             t.cur_depth + 1,
             -- once we've gone `depth` levels deep, freeze the bucket_id
             CASE WHEN t.cur_depth >= :depth THEN t.bucket_id ELSE f.id END
      FROM files f JOIN tree t ON f.parent_id = t.id
      WHERE t.is_excluded = 0   -- excluded dirs are leaf aggregates, don't recurse
        AND t.is_dir = 1        -- only recurse into directories
    ),
    multi_clones(clone_id) AS (
      SELECT clone_id FROM files WHERE clone_id IS NOT NULL
      GROUP BY clone_id HAVING COUNT(*) > 1
    )
    SELECT
      bucket_id,
      SUM(CASE WHEN is_dir = 0 OR is_excluded = 1 THEN size_blocks ELSE 0 END) AS total_blocks,
      SUM(CASE WHEN is_dir = 0 OR is_excluded = 1 THEN size_logical ELSE 0 END) AS total_logical,
      SUM(CASE WHEN is_dir = 0 THEN 1
               WHEN is_excluded = 1 THEN COALESCE(excluded_file_count, 0)
               ELSE 0 END) AS file_count,
      SUM(CASE WHEN clone_id IS NOT NULL
                    AND clone_id IN (SELECT clone_id FROM multi_clones)
                    AND is_dir = 0
               THEN size_blocks ELSE 0 END) AS clone_blocks
    FROM tree
    GROUP BY bucket_id
    ORDER BY
      CASE :sort_by
        WHEN 'logical' THEN SUM(CASE WHEN is_dir = 0 OR is_excluded = 1 THEN size_logical ELSE 0 END)
        ELSE SUM(CASE WHEN is_dir = 0 OR is_excluded = 1 THEN size_blocks ELSE 0 END)
      END DESC
    LIMIT :limit
    """

    rows = con.execute(sql, {
        "root_id":   root_id,
        "depth":     depth,
        "sort_by":   by,
        "limit":     limit,
    }).fetchall()

    if not rows:
        print("(no data)")
        return

    # Resolve bucket paths
    bucket_paths = []
    for r in rows:
        p = full_path(con, r["bucket_id"])
        bucket_paths.append(p)

    home = os.path.expanduser("~")
    names = [os.path.basename(p) or p for p in bucket_paths]
    reals = [fmt_bytes(r["total_blocks"]) for r in rows]
    apparents = [fmt_bytes_highlight(r["total_blocks"], r["total_logical"]) for r in rows]
    counts = [str(r["file_count"]) for r in rows]

    if args.json:
        out = []
        for path, name, r in zip(bucket_paths, names, rows):
            out.append({
                "path":        path,
                "name":        name,
                "blocks":      r["total_blocks"],
                "logical":     r["total_logical"],
                "clone_blocks": r["clone_blocks"],
                "file_count":  r["file_count"],
            })
        print(json.dumps(out, indent=2))
        return

    w_name  = col_width(names, "NAME")
    w_real  = col_width(reals, "REAL")
    w_appar = col_width(apparents, "APPARENT")
    w_count = col_width(counts, "FILES")

    header = (
        f"{'NAME':<{w_name}}  {'REAL':>{w_real}}  {'APPARENT':>{w_appar}}  {'FILES':>{w_count}}"
    )
    print(header)
    print("-" * len(header))
    for name, real, appar, count in zip(names, reals, apparents, counts):
        print(f"{name:<{w_name}}  {real:>{w_real}}  {appar:>{w_appar}}  {count:>{w_count}}")


# ---------------------------------------------------------------------------
# MARGINAL helpers (family-once semantics)
# ---------------------------------------------------------------------------

def _compute_marginal_freeable(con: sqlite3.Connection, root_id: int) -> dict:
    """
    Compute strict freeable bytes for a subtree using family-once semantics.
    - Clone family fully inside target: credit max(member blocks) once.
    - Hardlink family fully inside target: credit inode blocks once.
    - Singleton: credit blocks.
    Uses SQL for efficiency; no per-family Python loops over large datasets.
    Returns dict with strict_bytes, apparent_bytes, total_blocks, file_count, dir_count.
    """
    cte_sql, cte_params = descendant_ids_cte(root_id)

    # --- Counts (apparent, total_blocks, file_count, dir_count) ---
    counts_sql = cte_sql + """
    SELECT
      SUM(CASE WHEN f.is_dir=0 THEN 1 ELSE 0 END) AS file_count,
      SUM(CASE WHEN f.is_dir=1 AND f.is_excluded=0 THEN 1 ELSE 0 END) AS dir_count,
      SUM(CASE WHEN f.is_dir=0 THEN f.size_logical
               WHEN f.is_excluded=1 THEN f.size_logical ELSE 0 END) AS apparent,
      SUM(CASE WHEN f.is_dir=0 THEN f.size_blocks
               WHEN f.is_excluded=1 THEN f.size_blocks ELSE 0 END) AS total_blocks
    FROM files f JOIN desc_ids d ON f.id = d.id
    """
    counts = con.execute(counts_sql, cte_params).fetchone()

    # --- Strict freeable via SQL ---
    # Strategy: use a single SQL pass that identifies which families are
    # fully inside the target, then sums their credit.
    #
    # For clone families: family is fully inside if every member is in desc_ids.
    # Credit: MAX(size_blocks) per clone family.
    # For hardlink families: family is fully inside if inside_count == nlinks.
    # Credit: size_blocks once (any member — all same inode).
    # Singletons: their own size_blocks.
    #
    # Implementation: compute inside_count per family, total_count per family,
    # then filter for fully-inside families.

    # We use a Python-side approach for efficiency:
    # 1. Load inside_files in one CTE query
    # 2. Batch-fetch global clone counts for clone_ids present inside
    # 3. Batch-fetch global hl counts for (dev,ino) pairs present inside

    inside_sql = cte_sql + """
    SELECT f.id, f.dev, f.ino, f.clone_id, f.nlinks, f.size_blocks
    FROM files f JOIN desc_ids d ON f.id = d.id
    WHERE f.is_dir = 0
    """
    inside_rows = con.execute(inside_sql, cte_params).fetchall()

    # Group inside files
    clone_inside: dict[int, list] = collections.defaultdict(list)  # clone_id -> [size_blocks,...]
    hl_inside: dict[tuple, tuple] = {}   # (dev,ino) -> (inside_cnt, nlinks, blocks)
    singleton_blocks = 0

    for r in inside_rows:
        cid = r["clone_id"]
        if cid is not None:
            clone_inside[cid].append(r["size_blocks"])
        elif r["nlinks"] > 1:
            key = (r["dev"], r["ino"])
            if key not in hl_inside:
                hl_inside[key] = [1, r["nlinks"], r["size_blocks"]]
            else:
                hl_inside[key][0] += 1
        else:
            singleton_blocks += r["size_blocks"]

    # Get global clone counts for clone_ids seen inside the subtree.
    # Use batched IN queries (avoids temp table which needs write access).
    clone_strict = 0
    if clone_inside:
        clone_ids_list = list(clone_inside.keys())
        global_clone_map: dict[int, int] = {}
        # Batch in chunks of 500 to keep query size manageable
        _BATCH = 500
        for i in range(0, len(clone_ids_list), _BATCH):
            batch = clone_ids_list[i:i + _BATCH]
            placeholders = ",".join("?" * len(batch))
            rows_g = con.execute(
                f"SELECT clone_id, COUNT(*) AS cnt FROM files "
                f"WHERE clone_id IN ({placeholders}) GROUP BY clone_id",
                batch,
            ).fetchall()
            for rg in rows_g:
                global_clone_map[rg["clone_id"]] = rg["cnt"]

        for cid, blocks_list in clone_inside.items():
            inside_cnt = len(blocks_list)
            total_cnt = global_clone_map.get(cid, inside_cnt)
            if inside_cnt >= total_cnt:
                clone_strict += max(blocks_list)

    # Hardlink families
    hl_strict = 0
    for (dev, ino), (inside_cnt, nlinks, blocks) in hl_inside.items():
        if inside_cnt >= nlinks:
            hl_strict += blocks

    strict_blocks = clone_strict + hl_strict + singleton_blocks

    return {
        "strict_bytes": int(strict_blocks),
        "apparent_bytes": int(counts["apparent"] or 0),
        "total_blocks": int(counts["total_blocks"] or 0),
        "file_count": int(counts["file_count"] or 0),
        "dir_count": int(counts["dir_count"] or 0),
    }


# ---------------------------------------------------------------------------
# MARGINAL subcommand
# ---------------------------------------------------------------------------
def cmd_marginal(args: argparse.Namespace) -> None:
    path = os.path.realpath(args.path)
    con = open_db_for_read()
    _init_schema(con)

    root_id = resolve_path_to_id(con, path)
    if root_id is None:
        sys.exit(f"error: no data for path {path} — run `duh scan` first")

    result = _compute_marginal_freeable(con, root_id)
    strict_blocks    = result["strict_bytes"]
    total_apparent   = result["apparent_bytes"]
    total_blocks_all = result["total_blocks"]
    total_files      = result["file_count"]
    total_dirs       = result["dir_count"]

    # External leaks (top 5): files/families with members outside the target.
    # Use the already-computed result data from _compute_marginal_freeable.
    # We need to re-run the inside query to find files with external family members.
    # This is a fast Python-side computation reusing cached data.
    cte_sql, cte_params = descendant_ids_cte(root_id)
    inside_sql_leaks = cte_sql + """
    SELECT f.id, f.dev, f.ino, f.clone_id, f.nlinks, f.size_blocks
    FROM files f JOIN desc_ids d ON f.id = d.id
    WHERE f.is_dir = 0
    """
    inside_files_leaks = con.execute(inside_sql_leaks, cte_params).fetchall()
    inside_id_set = {r["id"] for r in inside_files_leaks}

    # Build family groups from inside files
    clone_grp_leaks: dict = collections.defaultdict(list)
    hl_grp_leaks: dict = collections.defaultdict(list)
    for r in inside_files_leaks:
        if r["clone_id"] is not None:
            clone_grp_leaks[r["clone_id"]].append(r)
        elif r["nlinks"] > 1:
            hl_grp_leaks[(r["dev"], r["ino"])].append(r)

    # Get global counts (batched)
    leak_clone_global: dict = {}
    if clone_grp_leaks:
        cids = list(clone_grp_leaks.keys())
        for i in range(0, len(cids), 500):
            batch = cids[i:i+500]
            phs = ",".join("?" * len(batch))
            for rg in con.execute(
                f"SELECT clone_id, COUNT(*) AS cnt FROM files "
                f"WHERE clone_id IN ({phs}) GROUP BY clone_id", batch
            ).fetchall():
                leak_clone_global[rg["clone_id"]] = rg["cnt"]

    # Collect leak candidates: families with members outside
    leak_candidates = []
    for cid, members in clone_grp_leaks.items():
        inside_cnt = len(members)
        total_cnt = leak_clone_global.get(cid, inside_cnt)
        if inside_cnt < total_cnt:
            # Some members outside — compute approximate blocks held outside
            max_blk = max(r["size_blocks"] for r in members)
            frac_outside = (total_cnt - inside_cnt) / total_cnt
            leak_candidates.append((
                members[0]["id"], max_blk * frac_outside,
                cid, None, None, members[0]["nlinks"]
            ))
    for (dev, ino), members in hl_grp_leaks.items():
        nlinks = members[0]["nlinks"]
        inside_cnt = len(members)
        if inside_cnt < nlinks:
            blk = members[0]["size_blocks"]
            frac_outside = (nlinks - inside_cnt) / nlinks
            leak_candidates.append((
                members[0]["id"], blk * frac_outside,
                None, dev, ino, nlinks
            ))

    leak_candidates.sort(key=lambda x: x[1], reverse=True)
    leak_rows = leak_candidates[:5]

    if args.json:
        out = {
            "path": path,
            "freeable_bytes": strict_blocks,
            "strict_marginal_bytes": strict_blocks,  # backward compat alias
            "apparent_bytes": total_apparent,
            "total_blocks_bytes": total_blocks_all,
            "file_count": total_files,
            "dir_count": total_dirs,
        }
        print(json.dumps(out, indent=2))
        return

    print(f"Marginal disk cost: {path}")
    print("  (family-once semantics: clone families count max(blocks) once, not per-member sum)")
    print()
    w = 24
    print(f"  {'Freeable (strict):':{w}} {fmt_bytes(strict_blocks):>12}  (what rm -rf returns to df)")
    print(f"  {'Apparent (du-style):':{w}} {fmt_bytes(total_apparent):>12}")
    print(f"  {'On-disk blocks:':{w}} {fmt_bytes(total_blocks_all):>12}")
    print(f"  {'Files:':{w}} {total_files:>12,}")
    print(f"  {'Dirs:':{w}} {total_dirs:>12,}")

    if leak_rows:
        print()
        print("  Blocks shared with paths OUTSIDE this directory (top 5):")
        home = os.path.expanduser("~")
        for (fid, blocks_ext, clone_id, dev, ino, nlinks) in leak_rows:
            fpath = full_path(con, fid)
            short_fpath = fpath.replace(home, "~")

            if clone_id is not None:
                ext_rows = con.execute(
                    "SELECT id FROM files WHERE clone_id = ? AND id NOT IN (?)",
                    (clone_id, ",".join(str(x) for x in inside_id_set)),
                ).fetchall()
                # Simplified: just show the clone_id family dirs
                ext_rows = con.execute(
                    "SELECT id FROM files WHERE clone_id = ? AND id != ?",
                    (clone_id, fid),
                ).fetchall()
                ext_ids = {r["id"] for r in ext_rows} - inside_id_set
                ext_rows_f = [{"id": eid} for eid in list(ext_ids)[:10]]
            else:
                ext_rows_f = con.execute(
                    "SELECT id FROM files WHERE dev = ? AND ino = ? AND nlinks > 1 AND id != ?",
                    (dev, ino, fid),
                ).fetchall()
                ext_rows_f = [r for r in ext_rows_f if r["id"] not in inside_id_set]

            ext_dirs = sorted({
                os.path.dirname(full_path(con, r["id"])).replace(home, "~")
                for r in ext_rows_f[:5]
            })
            ext_summary = ", ".join(ext_dirs[:2])
            print(f"    {fmt_bytes(int(blocks_ext)):>10}  {short_fpath}  → {ext_summary}")


