# --------------- pre-compute ------------------------------------------------

def _build_dir_agg(con: sqlite3.Connection) -> dict:
    """
    Walk the DB bottom-up and build dir_agg[file_id] = {
        total_blocks, total_logical, total_files, direct_blocks
    }
    for every directory.  Excluded subtree rows are treated as pre-summed
    leaves (their size_blocks / excluded_file_count are already aggregates).
    """
    t0 = time.time()
    print("[serve] pre-computing directory aggregates...", file=sys.stderr)

    # Load all rows in one pass
    print("[serve]   loading all file rows...", file=sys.stderr)
    rows = con.execute(
        "SELECT id, parent_id, is_dir, is_excluded, size_blocks, size_logical, "
        "       excluded_file_count "
        "FROM files"
    ).fetchall()
    print(f"[serve]   loaded {len(rows):,} rows in {time.time()-t0:.1f}s", file=sys.stderr)

    # Index: parent_id -> list of child rows
    children_of: dict[int | None, list] = {}
    all_ids: set[int] = set()
    for r in rows:
        pid = r["parent_id"]
        if pid not in children_of:
            children_of[pid] = []
        children_of[pid].append(r)
        all_ids.add(r["id"])

    # dir_agg accumulates totals; leaf files contribute directly
    dir_agg: dict[int, dict] = {}

    # Topological sort: process directories in leaf-first order using
    # an iterative post-order DFS.
    # Find root(s): parent_id IS NULL
    roots = [r for r in rows if r["parent_id"] is None]

    t1 = time.time()
    print(f"[serve]   starting bottom-up traversal ({len(roots)} root(s))...", file=sys.stderr)

    processed = 0
    stack: list[tuple] = []  # (row, phase)  phase=0 push children, phase=1 aggregate
    for root in roots:
        stack.append((root, 0))

    while stack:
        row, phase = stack.pop()
        fid = row["id"]

        if phase == 0:
            if row["is_dir"] and not row["is_excluded"]:
                # Push phase-1 marker first (runs after children)
                stack.append((row, 1))
                # Then push all children
                for child in children_of.get(fid, []):
                    stack.append((child, 0))
            elif row["is_excluded"]:
                # Excluded subtree: treat as leaf aggregate
                # Initialize its own entry so parent can find it
                dir_agg[fid] = {
                    "total_blocks": row["size_blocks"],
                    "total_logical": row["size_logical"],
                    "total_files": row["excluded_file_count"] or 0,
                    "direct_blocks": row["size_blocks"],
                }
            # non-dir leaf files are handled in their parent's phase-1
        else:
            # phase 1: aggregate children into this dir
            total_blocks = 0
            total_logical = 0
            total_files = 0
            direct_blocks = 0

            for child in children_of.get(fid, []):
                cid = child["id"]
                if child["is_dir"] and not child["is_excluded"]:
                    # Recursive subtree already computed
                    sub = dir_agg.get(cid)
                    if sub:
                        total_blocks += sub["total_blocks"]
                        total_logical += sub["total_logical"]
                        total_files += sub["total_files"]
                elif child["is_excluded"]:
                    # Excluded subtree leaf
                    total_blocks += child["size_blocks"]
                    total_logical += child["size_logical"]
                    total_files += child["excluded_file_count"] or 0
                    direct_blocks += child["size_blocks"]
                else:
                    # Regular file / symlink
                    total_blocks += child["size_blocks"]
                    total_logical += child["size_logical"]
                    total_files += 1
                    direct_blocks += child["size_blocks"]

            dir_agg[fid] = {
                "total_blocks": total_blocks,
                "total_logical": total_logical,
                "total_files": total_files,
                "direct_blocks": direct_blocks,
            }
            processed += 1
            if processed % 50000 == 0:
                elapsed = time.time() - t1
                print(f"[serve]   processed {processed:,} dirs in {elapsed:.1f}s", file=sys.stderr)

    elapsed = time.time() - t0
    print(f"[serve] pre-compute done: {len(dir_agg):,} dirs in {elapsed:.1f}s", file=sys.stderr)
    return dir_agg


# --------------- path cache -------------------------------------------------

class _PathCache:
    """Thread-safe memoized full_path() using per-thread DB connections."""
    def __init__(self, db_path: str):
        self._db_path = db_path
        self._cache: dict[int, str] = {}
        self._lock = threading.Lock()
        self._local = threading.local()

    def _get_con(self) -> sqlite3.Connection:
        con = getattr(self._local, "con", None)
        if con is None:
            con = sqlite3.connect(self._db_path)
            con.row_factory = sqlite3.Row
            con.execute("PRAGMA query_only = 1")
            self._local.con = con
        return con

    def get(self, file_id: int) -> str:
        with self._lock:
            if file_id in self._cache:
                return self._cache[file_id]
        path = full_path(self._get_con(), file_id)
        with self._lock:
            self._cache[file_id] = path
        return path


