def _marginal_for_id(con: sqlite3.Connection, root_id: int) -> dict:
    """Return freeable bytes for the given subtree (family-once semantics)."""
    t0 = time.time()
    result = _compute_marginal_freeable(con, root_id)
    duration_ms = int((time.time() - t0) * 1000)
    return {
        "id": root_id,
        "strict_bytes": result["strict_bytes"],
        "proportional_bytes": result["strict_bytes"],  # backward compat
        "apparent_bytes": result["apparent_bytes"],
        "duration_ms": duration_ms,
    }


