def cmd_excluded(args: argparse.Namespace) -> None:
    con = open_db_for_read()
    _init_schema(con)

    limit = args.limit
    rows = con.execute(
        "SELECT id, size_blocks, size_logical, excluded_file_count "
        "FROM files WHERE is_excluded = 1 "
        "ORDER BY size_blocks DESC "
        "LIMIT ?",
        (limit,),
    ).fetchall()

    if not rows:
