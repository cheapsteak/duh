"""


def cmd_sql(_args: argparse.Namespace) -> None:
    db_path = DB_PATH
    if not os.path.exists(db_path):
        sys.exit(f"error: DB not found: {db_path}\nRun `duh scan <path>` first.")

    import tempfile
    with tempfile.NamedTemporaryFile(mode="w", suffix=".sql", delete=False, prefix="duh-init-") as f:
        f.write(_VIEWS_SQL)
        init_file = f.name

    try:
        subprocess.run(["sqlite3", "-init", init_file, db_path], check=False)
    finally:
        os.unlink(init_file)


