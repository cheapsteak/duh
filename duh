# Default exclusions
# ---------------------------------------------------------------------------
DEFAULT_EXCLUDES = {
    "node_modules",
    ".venv",
    "venv",
    ".git/objects",
    ".terraform/providers",
    ".terraform/modules",
    ".next/cache",
    "__pycache__",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    "target",  # Rust
}

# Multi-component excludes (match on last N components of path)
_MULTI_COMPONENT_EXCLUDES = {
    ".git/objects",
    ".terraform/providers",
    ".terraform/modules",
    ".next/cache",
}

# Single-name excludes (match on directory name only)
_SINGLE_NAME_EXCLUDES = DEFAULT_EXCLUDES - _MULTI_COMPONENT_EXCLUDES


def build_excludes(args: argparse.Namespace) -> tuple[set[str], set[str]]:
    """Return (single_name_excludes, multi_component_excludes) based on CLI args."""
    if args.no_default_excludes:
        single = set()
        multi = set()
    else:
        single = set(_SINGLE_NAME_EXCLUDES)
        multi = set(_MULTI_COMPONENT_EXCLUDES)

    # --include removes from defaults
    for name in getattr(args, "include", []) or []:
        single.discard(name)
        multi.discard(name)

    # --exclude adds extra single-name patterns
    for name in getattr(args, "exclude", []) or []:
        single.add(name)

    return single, multi


def is_excluded(name: str, rel_path_from_root: str, single: set[str], multi: set[str]) -> bool:
    """Check if a directory entry should be excluded."""
    if name in single:
        return True
    # For multi-component patterns, check if rel_path ends with the pattern
    for pat in multi:
        if rel_path_from_root.endswith(pat) or rel_path_from_root == pat:
            return True
    return False


# ---------------------------------------------------------------------------
# Disk safety monitor
# ---------------------------------------------------------------------------
MIN_FREE_GIB_DEFAULT = 3.0
EX_TEMPFAIL = 75


def free_gib(path: str = None) -> float:
    """Return free GiB on the volume containing path."""
    check_path = path or DB_PATH
    try:
        s = os.statvfs(check_path)
        return (s.f_bavail * s.f_frsize) / (1024 ** 3)
    except OSError:
        return float("inf")


# ---------------------------------------------------------------------------
# DB helpers
# ---------------------------------------------------------------------------
def open_db(path: str = None, cache_mb: int = 64) -> sqlite3.Connection:
    p = path or DB_PATH
    os.makedirs(os.path.dirname(p), exist_ok=True)
    con = sqlite3.connect(p)
    con.row_factory = sqlite3.Row
    con.execute("PRAGMA journal_mode = WAL")
    con.execute("PRAGMA synchronous = NORMAL")
    con.execute(f"PRAGMA cache_size = -{cache_mb * 1000}")
    con.execute("PRAGMA foreign_keys = ON")
    return con


def open_db_for_read(path: str = None) -> sqlite3.Connection:
    """Open DB with 256 MB cache for analytical queries."""
    return open_db(path=path, cache_mb=256)


def _init_schema(con: sqlite3.Connection) -> None:
    con.executescript("""
    CREATE TABLE IF NOT EXISTS scans (
      id INTEGER PRIMARY KEY,
      root TEXT NOT NULL,
      started_at REAL NOT NULL,
      finished_at REAL,
      files_count INTEGER,
      excluded_count INTEGER,
      bytes_logical INTEGER,
      bytes_blocks INTEGER,
      schema_version INTEGER DEFAULT 2
    );

    CREATE TABLE IF NOT EXISTS files (
      id INTEGER PRIMARY KEY,
      parent_id INTEGER REFERENCES files(id),
      name TEXT NOT NULL,
      is_dir INTEGER NOT NULL,
      is_symlink INTEGER NOT NULL,
      is_excluded INTEGER NOT NULL DEFAULT 0,
      dev INTEGER NOT NULL,
      ino INTEGER NOT NULL,
      clone_id INTEGER,
      nlinks INTEGER NOT NULL,
      size_logical INTEGER NOT NULL,
      size_blocks INTEGER NOT NULL,
      excluded_file_count INTEGER,
      mtime INTEGER NOT NULL,
      scan_id INTEGER NOT NULL REFERENCES scans(id),
      UNIQUE(parent_id, name)
    );

    CREATE INDEX IF NOT EXISTS idx_files_parent ON files(parent_id);
    CREATE INDEX IF NOT EXISTS idx_files_clone ON files(clone_id) WHERE clone_id IS NOT NULL;
    CREATE INDEX IF NOT EXISTS idx_files_inode ON files(dev, ino) WHERE nlinks > 1;
    CREATE INDEX IF NOT EXISTS idx_files_excluded ON files(is_excluded) WHERE is_excluded = 1;

    CREATE TABLE IF NOT EXISTS excluded_families (
      excluded_id INTEGER NOT NULL REFERENCES files(id),
      clone_id INTEGER NOT NULL,
      member_count INTEGER NOT NULL,
      blocks_sum INTEGER NOT NULL,
      max_blocks INTEGER NOT NULL,
      PRIMARY KEY (excluded_id, clone_id)
    );
    CREATE INDEX IF NOT EXISTS idx_excluded_families_clone ON excluded_families(clone_id);
    """)
    con.commit()


# ---------------------------------------------------------------------------
# Path helpers
# ---------------------------------------------------------------------------
def full_path(con: sqlite3.Connection, file_id: int) -> str:
    """Reconstruct full filesystem path from file_id via recursive CTE."""
    rows = con.execute("""
      WITH RECURSIVE chain(id, parent_id, name) AS (
        SELECT id, parent_id, name FROM files WHERE id = ?
        UNION ALL
        SELECT f.id, f.parent_id, f.name FROM files f, chain c WHERE f.id = c.parent_id
      )
      SELECT name FROM chain
    """, (file_id,)).fetchall()
    parts = [r[0] for r in rows]
    parts.reverse()
    # parts[0] is the root entry name (e.g. "/" or "Users" etc.)
    # The root row has parent_id = NULL and name = the root dir name or "/"
    if not parts:
        return ""
    if parts[0] == "/":
        return "/" + "/".join(parts[1:])
    # Root stored as full path in name when it has no parent
    if len(parts) == 1:
        return parts[0]
    return parts[0] + "/" + "/".join(parts[1:])


def resolve_path_to_id(con: sqlite3.Connection, path: str) -> int | None:
    """Walk path components top-down in the DB to find the file_id."""
    # Find the root entry: parent_id IS NULL and name matches the root
    # The root row is inserted with parent_id=NULL and name=realpath(root)
    # For non-root paths, walk from the root row downward by name components
    norm = os.path.normpath(path)

    # Fast path: check if norm matches a root-level entry (parent_id IS NULL)
    row = con.execute(
        "SELECT id FROM files WHERE parent_id IS NULL AND name = ?", (norm,)
    ).fetchone()
    if row:
        return row[0]

    # Split into components and walk down
    parts = norm.split("/")
    # parts[0] == "" for absolute paths (leading slash)
    # Find root whose name starts with the path prefix
    # Strategy: find root entries, pick the one that is an ancestor of norm
    roots = con.execute(
        "SELECT id, name FROM files WHERE parent_id IS NULL"
    ).fetchall()

    start_id = None
    remaining = []
    for r in roots:
        rname = r["name"]
        if norm == rname:
            return r["id"]
        if norm.startswith(rname + "/"):
            suffix = norm[len(rname) + 1:]
            remaining = [p for p in suffix.split("/") if p]
            start_id = r["id"]
            break

    if start_id is None:
        return None

    cur_id = start_id
    for part in remaining:
        row = con.execute(
            "SELECT id FROM files WHERE parent_id = ? AND name = ?", (cur_id, part)
        ).fetchone()
        if not row:
            return None
        cur_id = row["id"]
    return cur_id


def descendant_ids_cte(file_id: int) -> tuple[str, dict]:
    """Return (CTE SQL fragment, params) that produces all descendant ids including the root."""
    sql = """
      WITH RECURSIVE desc_ids(id) AS (
        SELECT id FROM files WHERE id = :root_id
        UNION ALL
        SELECT f.id FROM files f JOIN desc_ids d ON f.parent_id = d.id
      )
    """
    return sql, {"root_id": file_id}


# ---------------------------------------------------------------------------
# Aggregate walk for excluded directories
# ---------------------------------------------------------------------------
def walk_for_aggregate(dir_path: str, root_dev: int) -> tuple[int, int, int, dict]:
    """Walk dir_path without inserting DB rows.
    Returns (blocks, logical, count, clone_families) where
    clone_families maps clone_id -> (count, blocks_sum, max_blocks).
    """
    total_blocks = 0
    total_logical = 0
    total_count = 0
    clone_families: dict[int, list] = {}  # clone_id -> [count, blocks_sum, max_blocks]
    stack = [dir_path]
    while stack:
        d = stack.pop()
        try:
            entries = list(os.scandir(d))
        except (PermissionError, OSError):
            continue
        for e in entries:
            try:
                st = e.stat(follow_symlinks=False)
            except OSError:
                continue
            if st.st_dev != root_dev:
                continue
            blk = st.st_blocks * 512
            total_blocks += blk
            total_logical += st.st_size
            total_count += 1
            if e.is_dir(follow_symlinks=False) and not e.is_symlink():
                stack.append(e.path)
            elif not e.is_symlink():
                # Try to get clone_id for non-symlink files
                try:
                    cid = get_clone_id(e.path)
                except Exception:
                    cid = None
                if cid is not None:
                    if cid not in clone_families:
                        clone_families[cid] = [0, 0, 0]
                    rec = clone_families[cid]
                    rec[0] += 1
                    rec[1] += blk
                    if blk > rec[2]:
                        rec[2] = blk
    # Convert to immutable tuples
    result: dict[int, tuple[int, int, int]] = {
        cid: (v[0], v[1], v[2]) for cid, v in clone_families.items()
    }
    return total_blocks, total_logical, total_count, result


# ---------------------------------------------------------------------------
# SCAN subcommand
# ---------------------------------------------------------------------------
_BATCH_SIZE = 1000
_PROGRESS_INTERVAL = 5.0
_DISK_CHECK_INTERVAL = 10.0

_INSERT_FILE_SQL = """
INSERT OR IGNORE INTO files
  (parent_id, name, is_dir, is_symlink, is_excluded, dev, ino, clone_id,
   nlinks, size_logical, size_blocks, excluded_file_count, mtime, scan_id)
VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)
"""

_INSERT_DIR_SQL = """
INSERT OR IGNORE INTO files
  (parent_id, name, is_dir, is_symlink, is_excluded, dev, ino, clone_id,
   nlinks, size_logical, size_blocks, excluded_file_count, mtime, scan_id)
VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)
"""


def _insert_dir_get_id(
    con: sqlite3.Connection,
    parent_id: int | None,
    name: str,
    is_excluded: int,
    dev: int,
    ino: int,
    clone_id: int | None,
    nlinks: int,
    size_logical: int,
    size_blocks: int,
    excluded_file_count: int | None,
    mtime: int,
    scan_id: int,
) -> int:
    """Insert a directory row and return its id."""
    cur = con.execute(_INSERT_DIR_SQL, (
        parent_id, name, 1, 0, is_excluded, dev, ino, clone_id,
        nlinks, size_logical, size_blocks, excluded_file_count, mtime, scan_id,
    ))
    if cur.lastrowid and cur.lastrowid > 0:
        return cur.lastrowid
    # Row already existed (IGNORE fired) — look it up
    row = con.execute(
        "SELECT id FROM files WHERE parent_id IS ? AND name = ? AND scan_id = ?",
        (parent_id, name, scan_id),
    ).fetchone()
    if row:
        return row[0]
    raise RuntimeError(f"Failed to insert/find dir row: parent={parent_id} name={name!r}")


def cmd_scan(args: argparse.Namespace) -> None:
    root = os.path.realpath(args.path)
    if not os.path.exists(root):
        sys.exit(f"error: path not found: {root}")

    min_free = args.min_free
    con = open_db(cache_mb=64)
    _init_schema(con)

    # --rescan: delete existing rows for this root
    if args.rescan:
        # Find the scan(s) for this root and delete their file rows
        old_scans = con.execute(
            "SELECT id FROM scans WHERE root = ?", (root,)
        ).fetchall()
        for s in old_scans:
            # Delete excluded_families BEFORE files (FK constraint)
            con.execute(
                "DELETE FROM excluded_families WHERE excluded_id IN "
                "(SELECT id FROM files WHERE scan_id = ?)",
                (s["id"],)
            )
            con.execute("DELETE FROM files WHERE scan_id = ?", (s["id"],))
        con.execute("DELETE FROM scans WHERE root = ?", (root,))
        con.commit()
        print(f"[rescan] deleted existing scan rows for {root}", file=sys.stderr)

    # Create scan record first so we can always mark finished_at on abort
    started_at = time.time()
    cur = con.execute(
        "INSERT INTO scans (root, started_at, schema_version) VALUES (?, ?, 2)",
        (root, started_at),
    )
    scan_id = cur.lastrowid
    con.commit()

    # Check free space before starting scan body
    db_dir = os.path.dirname(os.path.abspath(DB_PATH))
    current_free = free_gib(db_dir)
    if current_free < min_free:
        con.execute(
            "UPDATE scans SET finished_at=?, files_count=0, excluded_count=0, "
            "bytes_logical=0, bytes_blocks=0 WHERE id=?",
            (time.time(), scan_id),
        )
        con.commit()
        print(
            f"error: free disk below {min_free} GiB "
            f"(currently {current_free:.2f} GiB), aborting scan",
            file=sys.stderr,
        )
        sys.exit(EX_TEMPFAIL)

    try:
        root_stat = os.lstat(root)
        root_dev = root_stat.st_dev
    except OSError as e:
        sys.exit(f"error: cannot stat root: {e}")

    # Build exclude sets
    single_excludes, multi_excludes = build_excludes(args)

    total_files = 0
    total_logical = 0
    total_blocks = 0
    total_excluded = 0
    batch: list[tuple] = []

    last_progress = time.time()
    last_disk_check = time.time()
    scan_start = time.time()
    interrupted = False
    disk_abort = False

    def flush() -> None:
        nonlocal batch
        if batch:
            con.executemany(_INSERT_FILE_SQL, batch)
            con.commit()
            batch = []

    def handle_sigint(sig, frame) -> None:
        nonlocal interrupted
        interrupted = True

    signal.signal(signal.SIGINT, handle_sigint)

    # Insert root dir itself first to get its id
    root_clone = None
    if not args.no_clones:
        try:
            root_clone = get_clone_id(root)
        except Exception:
            pass

    root_name = root  # Store full path as name for the root node (no parent)
    root_dir_id = _insert_dir_get_id(
        con,
        parent_id=None,
        name=root_name,
        is_excluded=0,
        dev=root_stat.st_dev,
        ino=root_stat.st_ino,
        clone_id=root_clone,
        nlinks=root_stat.st_nlink,
        size_logical=root_stat.st_size,
        size_blocks=root_stat.st_blocks * 512,
        excluded_file_count=None,
        mtime=int(root_stat.st_mtime),
        scan_id=scan_id,
    )
    con.commit()

    # Stack entries: (parent_id, dir_path, rel_path_from_root)
    dirs_to_visit: list[tuple[int, str, str]] = [(root_dir_id, root, "")]
    permission_errors: set[str] = set()

    while dirs_to_visit and not interrupted and not disk_abort:
        parent_id, current_dir, rel_from_root = dirs_to_visit.pop()

        try:
            entries = list(os.scandir(current_dir))
        except PermissionError:
            if current_dir not in permission_errors:
                print(f"error: permission denied: {current_dir}", file=sys.stderr)
                permission_errors.add(current_dir)
            continue
        except OSError as e:
            print(f"error: scandir {current_dir}: {e}", file=sys.stderr)
            continue

        for entry in entries:
            if interrupted or disk_abort:
                break

            try:
                st = entry.stat(follow_symlinks=False)
            except OSError:
                continue

            if not args.cross_device and st.st_dev != root_dev:
                continue

            name = entry.name
            is_dir = entry.is_dir(follow_symlinks=False)
            is_symlink = entry.is_symlink()
            dev = st.st_dev
            ino = st.st_ino
            nlinks = st.st_nlink
            size_logical = st.st_size
            size_blocks = st.st_blocks * 512
            mtime = int(st.st_mtime)
            entry_rel = (rel_from_root + "/" + name).lstrip("/") if rel_from_root else name

            # Exclusion check (dirs only)
            if is_dir and not is_symlink:
                if is_excluded(name, entry_rel, single_excludes, multi_excludes):
                    flush()
                    agg_blocks, agg_logical, agg_count, clone_families = walk_for_aggregate(entry.path, root_dev)
                    excl_id = _insert_dir_get_id(
                        con,
                        parent_id=parent_id,
                        name=name,
                        is_excluded=1,
                        dev=dev,
                        ino=ino,
                        clone_id=None,
                        nlinks=nlinks,
                        size_logical=agg_logical,
                        size_blocks=agg_blocks,
                        excluded_file_count=agg_count,
                        mtime=mtime,
                        scan_id=scan_id,
                    )
                    # Insert clone family data for this excluded subtree
                    for cid, (cnt, bsum, bmax) in clone_families.items():
                        con.execute(
                            "INSERT OR REPLACE INTO excluded_families "
                            "(excluded_id, clone_id, member_count, blocks_sum, max_blocks) "
                            "VALUES (?,?,?,?,?)",
                            (excl_id, cid, cnt, bsum, bmax),
                        )
                    con.commit()
                    total_excluded += 1
                    continue  # don't recurse

            clone_id = None
            if not args.no_clones and not is_symlink:
                try:
                    clone_id = get_clone_id(entry.path)
                except Exception:
                    pass

            if is_dir and not is_symlink:
                # Insert dir, get its id, then recurse
                flush()
                new_id = _insert_dir_get_id(
                    con,
                    parent_id=parent_id,
                    name=name,
                    is_excluded=0,
                    dev=dev,
                    ino=ino,
                    clone_id=clone_id,
                    nlinks=nlinks,
                    size_logical=size_logical,
                    size_blocks=size_blocks,
                    excluded_file_count=None,
                    mtime=mtime,
                    scan_id=scan_id,
                )
                con.commit()
                dirs_to_visit.append((new_id, entry.path, entry_rel))
            else:
                # Leaf file or symlink — batch insert
                batch.append((
                    parent_id, name,
                    0,  # is_dir
                    1 if is_symlink else 0,
                    0,  # is_excluded
                    dev, ino, clone_id,
                    nlinks, size_logical, size_blocks,
                    None,  # excluded_file_count
                    mtime, scan_id,
                ))

                total_files += 1
                total_logical += size_logical
                total_blocks += size_blocks

                if len(batch) >= _BATCH_SIZE:
                    flush()

            now = time.time()

            # Progress
            if not args.quiet and now - last_progress >= _PROGRESS_INTERVAL:
                elapsed = now - scan_start
                rate = total_files / elapsed if elapsed > 0 else 0
                print(
                    f"[{total_files:,} files, {total_excluded} excluded, "
                    f"{fmt_bytes(total_blocks)} scanned, {rate:.0f} files/sec]",
                    file=sys.stderr,
                )
                last_progress = now

            # Disk safety check
            if now - last_disk_check >= _DISK_CHECK_INTERVAL:
                current_free = free_gib(db_dir)
                if current_free < min_free:
                    print(
                        f"error: free disk below {min_free} GiB "
                        f"(currently {current_free:.2f} GiB), aborting scan",
                        file=sys.stderr,
                    )
                    disk_abort = True
                last_disk_check = now

    flush()

    # Update scan record
    con.execute(
        "UPDATE scans SET finished_at=?, files_count=?, excluded_count=?, "
        "bytes_logical=?, bytes_blocks=? WHERE id=?",
        (time.time(), total_files, total_excluded, total_logical, total_blocks, scan_id),
    )
    con.commit()

    # Invalidate freeable cache: scan data changed, and scan_id may be reused
    # (SQLite reuses rowids after --rescan deletes the old scans row), so
    # stale freeable_cache rows would otherwise look valid.
    try:
        con.execute("DELETE FROM freeable_cache")
        con.commit()
        print("[scan] freeable cache invalidated", file=sys.stderr)
    except sqlite3.OperationalError:
        pass  # table doesn't exist yet (no freeable run since DB creation)

    if disk_abort:
        sys.exit(EX_TEMPFAIL)

    if interrupted:
        print(f"\n[interrupted] partial scan committed: {total_files:,} files", file=sys.stderr)
        sys.exit(130)

    elapsed = time.time() - started_at
    rate = total_files / elapsed if elapsed > 0 else 0
    if not args.quiet:
        print(
            f"Scan complete: {total_files:,} files, {total_excluded} excluded dirs "
            f"in {elapsed:.1f}s ({rate:.0f} files/sec)\n"
            f"  logical: {fmt_bytes(total_logical)}  blocks: {fmt_bytes(total_blocks)}\n"
            f"  DB: {DB_PATH}",
            file=sys.stderr,
        )


