# ---------------------------------------------------------------------------
# CLONES subcommand
# ---------------------------------------------------------------------------
def cmd_clones(args: argparse.Namespace) -> None:
    con = open_db_for_read()
    _init_schema(con)

    under = args.under
    min_bytes = args.min_bytes
    limit = args.limit

    if under:
        under = os.path.realpath(under)
        root_id = resolve_path_to_id(con, under)
        if root_id is None:
            sys.exit(f"error: path not found in DB: {under}")

        cte_sql, cte_params = descendant_ids_cte(root_id)
        query = cte_sql + """
        SELECT clone_id, id, size_blocks FROM files
        WHERE clone_id IS NOT NULL AND id IN (SELECT id FROM desc_ids)
        """
        rows = con.execute(query, cte_params).fetchall()
    else:
        rows = con.execute(
            "SELECT clone_id, id, size_blocks FROM files WHERE clone_id IS NOT NULL"
        ).fetchall()

    from collections import defaultdict
    fam_blocks: dict[int, int] = defaultdict(int)
    fam_count: dict[int, int] = defaultdict(int)
    fam_ids: dict[int, list[int]] = defaultdict(list)

    for r in rows:
        cid = r["clone_id"]
        fam_blocks[cid] += r["size_blocks"]
        fam_count[cid] += 1
        fam_ids[cid].append(r["id"])

    families = [
        (cid, fam_count[cid], fam_blocks[cid], fam_ids[cid])
        for cid in fam_blocks
        if fam_count[cid] > 1 and fam_blocks[cid] >= min_bytes
    ]
    families.sort(key=lambda x: (x[2] // x[1]) * max(x[1] - 1, 0), reverse=True)
    families = families[:limit]

    if not families:
        print("(no clone families found)")
        return

    home = os.path.expanduser("~")

    if args.json:
        out = []
        for cid, count, blocks, ids in families:
            sample_paths = [full_path(con, i).replace(home, "~") for i in ids[:3]]
            out.append({
                "clone_id": cid,
                "member_count": count,
                "blocks_each": blocks // count if count else 0,
                "blocks_total": blocks,
                "waste_bytes": blocks * max(count - 1, 0),
                "sample_paths": sample_paths,
            })
        print(json.dumps(out, indent=2))
        return

    print(f"{'CLONE_ID':<18}  {'COUNT':>5}  {'BLOCKS_EACH':>12}  {'WASTE':>12}  PATHS (sample)")
    print("-" * 90)
    for cid, count, blocks, ids in families:
        each = blocks // count if count else 0
        waste = each * max(count - 1, 0)
        sample = [full_path(con, i).replace(home, "~") for i in ids[:3]]
        print(f"{cid:<18}  {count:>5}  {fmt_bytes(each):>12}  {fmt_bytes(waste):>12}  {sample[0]}")
        for p in sample[1:]:
            print(f"{'':18}  {'':>5}  {'':>12}  {'':>12}  {p}")


