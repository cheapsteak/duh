# FREEABLE subcommand (debug/verification)
# ---------------------------------------------------------------------------
def cmd_freeable(args: argparse.Namespace) -> None:
    """Show freeable bytes for a path (precomputed, family-once semantics)."""
    path = os.path.realpath(args.path)
    con = open_db_for_read()
    _init_schema(con)

    node_id = resolve_path_to_id(con, path)
    if node_id is None:
        sys.exit(f"error: path not in DB: {path}\nRun `duh scan` first.")

    freeable_map, locked_here_map = compute_freeable(con)

    f = freeable_map.get(node_id, 0)
    lh = locked_here_map.get(node_id, 0)
    print(f"Path: {path}")
    print(f"  Freeable:    {fmt_bytes(f)}")
    print(f"  Locked here: {fmt_bytes(lh)}")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------
def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="duh",
        description="macOS APFS-aware disk-usage database (v2). Detects clones and hardlinks.",
    )
    p.add_argument("--db", default=None, help="Override DB path (or set DUH_DB env var)")
    sub = p.add_subparsers(dest="command", required=True)

    # selftest
    sub.add_parser("selftest", help="Verify APFS clone detection (ctypes getattrlist test)")

    # scan
    ps = sub.add_parser("scan", help="Walk a directory and index files")
    ps.add_argument("path")
    ps.add_argument("--quiet", "-q", action="store_true")
    ps.add_argument("--no-clones", action="store_true", help="Skip clone_id detection (faster)")
    ps.add_argument("--rescan", action="store_true", help="Delete existing scan for this root before scanning")
    ps.add_argument("--cross-device", action="store_true", help="Follow mounts into other filesystems")
    ps.add_argument("--min-free", type=float, default=MIN_FREE_GIB_DEFAULT, metavar="GIB",
                    help=f"Abort scan if free disk drops below N GiB (default {MIN_FREE_GIB_DEFAULT})")
    ps.add_argument("--exclude", action="append", metavar="NAME", default=[],
                    help="Add a directory name to the exclusion list (repeatable)")
    ps.add_argument("--include", action="append", metavar="NAME", default=[],
                    help="Remove a name from the default exclusion list (repeatable)")
    ps.add_argument("--no-default-excludes", action="store_true",
                    help="Don't apply the default exclusion list")

    # top
    pt = sub.add_parser("top", help="Show top directories by size")
    pt.add_argument("--under", default=None, help="Limit to this path prefix")
    pt.add_argument("--by", default="blocks", choices=["blocks", "logical", "clones"])
    pt.add_argument("--limit", "-n", type=int, default=20)
    pt.add_argument("--depth", "-d", type=int, default=1)
    pt.add_argument("--json", action="store_true")

    # marginal
    pm = sub.add_parser("marginal", help="Show marginal disk cost of a path")
    pm.add_argument("path")
    pm.add_argument("--json", action="store_true")

    # file
    pf = sub.add_parser("file", help="Show metadata for a single file")
    pf.add_argument("path")

    # clones
    pc = sub.add_parser("clones", help="Rank clone families by waste")
    pc.add_argument("--under", default=None)
    pc.add_argument("--min-bytes", type=int, default=1024 * 1024, metavar="N")
    pc.add_argument("--limit", "-n", type=int, default=20)
    pc.add_argument("--json", action="store_true")

    # excluded (NEW)
    pe = sub.add_parser("excluded", help="List excluded subtrees with aggregate sizes")
    pe.add_argument("--limit", "-n", type=int, default=50)

    # clusters
    pc2 = sub.add_parser("clusters", help="Report top delete-together groups by locked-at size")
    pc2.add_argument("--min-bytes", type=int, default=100 * 1024 * 1024, metavar="N")
    pc2.add_argument("--limit", "-n", type=int, default=20)
    pc2.add_argument("--json", action="store_true")

    # freeable (debug/verification)
    pfr = sub.add_parser("freeable", help="Show precomputed freeable bytes for a path")
    pfr.add_argument("path")

    # sql
    sub.add_parser("sql", help="Open DB in sqlite3 with helpful views")

    # stats
    sub.add_parser("stats", help="Show summary of last scan")

    # serve
    pserve = sub.add_parser("serve", help="Launch local web UI (treesize-style disk explorer)")
    pserve.add_argument("--port", type=int, default=7777,
                        help="Starting port (tries up to port+10 if taken, default 7777)")
    pserve.add_argument("--no-browser", action="store_true",
                        help="Don't auto-open browser")

    return p


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    global DB_PATH
    if args.db:
        DB_PATH = args.db

    dispatch = {
        "selftest": cmd_selftest,
        "scan":     cmd_scan,
        "top":      cmd_top,
        "marginal": cmd_marginal,
        "file":     cmd_file,
        "clones":   cmd_clones,
        "excluded": cmd_excluded,
        "clusters": cmd_clusters,
        "freeable": cmd_freeable,
        "sql":      cmd_sql,
        "stats":    cmd_stats,
        "serve":    cmd_serve,
    }

    fn = dispatch.get(args.command)
    if fn is None:
        parser.print_help()
        sys.exit(1)
    fn(args)


if __name__ == "__main__":
    main()
