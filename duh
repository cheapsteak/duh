# ---------------------------------------------------------------------------
# FREEABLE computation (LCA-based, family-once semantics) — streaming/array version
# ---------------------------------------------------------------------------

def _lca_arr(node_a: int, node_b: int, depth_arr: array.array, parent_arr: array.array,
             max_id: int) -> int:
    """Compute LCA of two nodes using dense arrays. Returns -1 if no common ancestor."""
    a, b = node_a, node_b
    if a < 0 or a > max_id or b < 0 or b > max_id:
        return -1
    da = depth_arr[a]
    db = depth_arr[b]
    if da < 0 or db < 0:
        return -1
    while da > db:
        a = parent_arr[a]
        if a < 0:
            return -1
        da -= 1
    while db > da:
        b = parent_arr[b]
        if b < 0:
            return -1
        db -= 1
    while a != b:
        pa = parent_arr[a]
        pb = parent_arr[b]
        if pa < 0 and pb < 0:
            return -1
        a = pa if pa >= 0 else a
        b = pb if pb >= 0 else b
    return a


def _direct_child_of_arr(ancestor_id: int, descendant_id: int,
                          parent_arr: array.array) -> int:
    """Find the direct child of ancestor_id on the path to descendant_id."""
    cur = descendant_id
    while True:
        p = parent_arr[cur]
        if p < 0 or p == ancestor_id:
            return cur
        cur = p


def _get_latest_scan_id(con: sqlite3.Connection) -> int | None:
    row = con.execute("SELECT id FROM scans ORDER BY id DESC LIMIT 1").fetchone()
    return row[0] if row else None


def _load_freeable_cache(con: sqlite3.Connection, scan_id: int) -> tuple[dict, dict] | None:
    """Try to load freeable results from cache. Returns (freeable, locked_here) or None."""
    try:
        row = con.execute(
            "SELECT COUNT(*) AS cnt FROM freeable_cache WHERE scan_id = ?", (scan_id,)
        ).fetchone()
        if not row or row[0] == 0:
            return None
        print(f"[freeable] loading from cache (scan_id={scan_id})...", file=sys.stderr)
        t0 = time.time()
        freeable: dict[int, int] = {}
        locked_here: dict[int, int] = {}
        for r in con.execute(
            "SELECT node_id, freeable, locked_here FROM freeable_cache WHERE scan_id = ?",
            (scan_id,)
        ):
            nid = r[0]
            if r[1]:
                freeable[nid] = r[1]
            if r[2]:
                locked_here[nid] = r[2]
        print(
            f"[freeable] cache loaded: {len(freeable):,} freeable, "
            f"{len(locked_here):,} locked_here in {time.time()-t0:.1f}s",
            file=sys.stderr
        )
        return freeable, locked_here
    except sqlite3.OperationalError:
        return None


def _persist_freeable_cache(
    db_path: str,
    scan_id: int,
    freeable: dict,
    locked_here: dict,
) -> None:
    """Write freeable results to cache table in a separate writable connection."""
    try:
        wcon = sqlite3.connect(db_path, timeout=30)
        wcon.execute("PRAGMA journal_mode = WAL")
        wcon.execute("PRAGMA synchronous = NORMAL")
        wcon.executescript("""
        CREATE TABLE IF NOT EXISTS freeable_cache (
          node_id INTEGER PRIMARY KEY,
          freeable INTEGER NOT NULL,
          locked_here INTEGER NOT NULL,
          scan_id INTEGER NOT NULL
        );
        """)
        # Clear stale cache rows (different scan_id)
        wcon.execute("DELETE FROM freeable_cache WHERE scan_id != ?", (scan_id,))

        # Merge freeable and locked_here into rows (only non-zero)
        all_ids = set(freeable.keys()) | set(locked_here.keys())
        batch = []
        for nid in all_ids:
            f = freeable.get(nid, 0)
            lh = locked_here.get(nid, 0)
            if f or lh:
                batch.append((nid, f, lh, scan_id))
        # Insert in chunks
        chunk = 10000
        for i in range(0, len(batch), chunk):
            wcon.executemany(
                "INSERT OR REPLACE INTO freeable_cache (node_id, freeable, locked_here, scan_id) "
                "VALUES (?,?,?,?)",
                batch[i:i+chunk],
            )
        wcon.commit()
        wcon.close()
        print(
            f"[freeable] cache written: {len(batch):,} rows for scan_id={scan_id}",
            file=sys.stderr,
        )
    except Exception as e:
        print(f"[freeable] warning: could not write cache: {e}", file=sys.stderr)


def compute_freeable(con: sqlite3.Connection) -> tuple[dict, dict]:
    """
    Compute freeable bytes for every directory node.
    Returns (freeable, locked_here) where both are dict[node_id -> bytes].

    Freeable(dir) = sum of family credits whose LCA is in dir's subtree.
    Locked_here(dir) = credits whose LCA is exactly this node AND members
                       span 2+ distinct direct children of this node.

    Uses streaming queries + dense arrays to stay under 1.5 GB peak RSS.
    Results are cached in freeable_cache table keyed by scan_id.
    """
    t0 = time.time()

    # Check cache first
    scan_id = _get_latest_scan_id(con)
    if scan_id is not None:
        cached = _load_freeable_cache(con, scan_id)
        if cached is not None:
            return cached

    print("[freeable] computing from scratch (no valid cache)...", file=sys.stderr)

    # ------------------------------------------------------------------
    # Step 1: Build dense arrays for parent_id and depth indexed by node_id
    # ------------------------------------------------------------------
    print("[freeable] building parent/depth arrays...", file=sys.stderr)
    t1 = time.time()

    max_id_row = con.execute("SELECT MAX(id) FROM files").fetchone()
    max_id: int = max_id_row[0] if max_id_row and max_id_row[0] else 0

    # array('q') = signed 64-bit. Use -1 as sentinel (no parent = root).
    # parent_arr[i] = parent_id of node i, or -1 if root or not present
    parent_arr = array.array('q', [-1] * (max_id + 1))
    # depth_arr[i] = depth of node i (-1 = not yet set)
    depth_arr = array.array('i', [-1] * (max_id + 1))
    # is_dir_arr[i]: 0=file/not-present, 1=regular dir, 2=excluded dir
    is_dir_arr = array.array('b', [0] * (max_id + 1))
    # size_blocks for excluded dirs (leaf aggregate)
    excl_blocks_arr = array.array('q', [0] * (max_id + 1))

    roots_list: list[int] = []
    children_map: dict[int, list[int]] = collections.defaultdict(list)

    for row in con.execute(
        "SELECT id, parent_id, is_dir, is_excluded, size_blocks FROM files"
    ):
        nid: int = row[0]
        pid = row[1]
        is_dir: int = row[2]
        is_excl: int = row[3]
        blk: int = row[4]

        if pid is None:
            parent_arr[nid] = -1
            roots_list.append(nid)
        else:
            parent_arr[nid] = pid
            children_map[pid].append(nid)

        if is_dir:
            is_dir_arr[nid] = 2 if is_excl else 1
        if is_excl:
            excl_blocks_arr[nid] = blk

    # BFS to compute depths
    q: collections.deque = collections.deque()
    for r in roots_list:
        depth_arr[r] = 0
        q.append(r)
    while q:
        nid = q.popleft()
        d = depth_arr[nid]
        for child in children_map.get(nid, []):
            if depth_arr[child] < 0:
                depth_arr[child] = d + 1
                q.append(child)

    print(
        f"[freeable] arrays built in {time.time()-t1:.1f}s, max_id={max_id:,}",
        file=sys.stderr,
    )

    # ------------------------------------------------------------------
    # Step 2: Build excluded-blocks-sum dict (per excluded_id)
    # One GROUP BY query => ~3,812 entries
    # ------------------------------------------------------------------
    excl_ef_total: dict[int, int] = {}
    try:
        for row in con.execute(
            "SELECT excluded_id, SUM(blocks_sum) AS total FROM excluded_families "
            "GROUP BY excluded_id"
        ):
            excl_ef_total[row[0]] = row[1] or 0
    except sqlite3.OperationalError:
        pass  # table may not exist on older DBs

    # ------------------------------------------------------------------
    # Step 3: Build temp table of multi-member clone_ids
    # This avoids materialising a Python set of 2.4M ids.
    # ------------------------------------------------------------------
    print("[freeable] building multi-clone temp table...", file=sys.stderr)
    t3 = time.time()
    try:
        con.execute("DROP TABLE IF EXISTS temp.multi_cids")
    except Exception:
        pass
    try:
        con.executescript("""
        CREATE TEMP TABLE multi_cids AS
          SELECT clone_id FROM (
            SELECT clone_id FROM files WHERE clone_id IS NOT NULL AND is_dir=0
            UNION ALL
            SELECT clone_id FROM excluded_families
          ) GROUP BY clone_id HAVING COUNT(*) > 1;
        CREATE INDEX temp.idx_mc ON multi_cids(clone_id);
        """)
    except sqlite3.OperationalError:
        # excluded_families may not exist — fall back to files-only
        try:
            con.execute("DROP TABLE IF EXISTS temp.multi_cids")
        except Exception:
            pass
        con.executescript("""
        CREATE TEMP TABLE multi_cids AS
          SELECT clone_id FROM files
          WHERE clone_id IS NOT NULL AND is_dir=0
          GROUP BY clone_id HAVING COUNT(*) > 1;
        CREATE INDEX temp.idx_mc ON multi_cids(clone_id);
        """)
    print(
        f"[freeable] multi_cids table built in {time.time()-t3:.1f}s", file=sys.stderr
    )

    # ------------------------------------------------------------------
    # Step 4: Streaming clone + excluded-family pass (one family at a time)
    # ------------------------------------------------------------------
    print("[freeable] streaming clone families...", file=sys.stderr)
    t4 = time.time()

    # credit_arr[i] = direct credit assigned to node i
    credit_arr = array.array('q', [0] * (max_id + 1))
    # locked_contrib: list of (lca_node, credit_bytes, child_set)
    locked_contrib: list = []

    # Union stream: real file members (is_excl=0) and excluded pseudo-members (is_excl=1)
    # The stream yields: (clone_id, is_excl, node_id, blocks)
    # where for real files blocks = size_blocks, for excl = max_blocks (per ef row)
    try:
        stream_sql = """
        SELECT clone_id, 0 AS is_excl, id AS node_id, size_blocks AS blocks
          FROM files
          WHERE clone_id IS NOT NULL AND is_dir=0
        UNION ALL
        SELECT clone_id, 1, excluded_id, max_blocks
          FROM excluded_families
        ORDER BY clone_id
        """
        cur_stream = con.execute(stream_sql)
    except sqlite3.OperationalError:
        # excluded_families missing -- files only
        stream_sql = """
        SELECT clone_id, 0 AS is_excl, id AS node_id, size_blocks AS blocks
          FROM files
          WHERE clone_id IS NOT NULL AND is_dir=0
        ORDER BY clone_id
        """
        cur_stream = con.execute(stream_sql)

    # We process one family at a time: accumulate members, then when clone_id changes, finalize.
    fam_cid: int = -1
    fam_members: list = []    # list of (node_id, blocks, is_excl)
    fam_max_blocks: int = 0
    families_processed = 0

    def _finalize_clone_family(cid: int, members: list, max_blk: int) -> None:
        """Process one clone family: compute LCA, assign credit, record locked_contrib."""
        if len(members) < 2:
            # Singleton family — will be handled in singleton pass
            return

        # Incremental LCA: running_lca starts at first member, updated with each subsequent
        running_lca: int = -1
        # We still need to hold member node_ids for the child_span check (families are small)
        member_ids: list[int] = []

        for (nid, blk, is_excl) in members:
            if nid > max_id or depth_arr[nid] < 0:
                # Member not in our tree (outside scanned roots) -- skip entire family
                return
            member_ids.append(nid)
            if running_lca < 0:
                running_lca = nid
            else:
                running_lca = _lca_arr(running_lca, nid, depth_arr, parent_arr, max_id)
                if running_lca < 0:
                    return  # spans multiple roots

        if running_lca < 0:
            return

        credit_arr[running_lca] += max_blk

        # child_span check for locked_here
        child_set: set = set()
        for nid in member_ids:
            if nid == running_lca:
                child_set.add(running_lca)
            else:
                dc = _direct_child_of_arr(running_lca, nid, parent_arr)
                child_set.add(dc)

        if len(child_set) >= 2:
            locked_contrib.append((running_lca, max_blk, child_set))

    for row in cur_stream:
        cid = row[0]
        is_excl = row[1]
        nid = row[2]
        blk = row[3]

        if cid != fam_cid:
            # Finalize previous family
            if fam_cid >= 0:
                _finalize_clone_family(fam_cid, fam_members, fam_max_blocks)
                families_processed += 1
                if families_processed % 100000 == 0:
                    elapsed_f = time.time() - t4
                    print(
                        f"[freeable]   clone families: {families_processed:,} "
                        f"in {elapsed_f:.1f}s",
                        file=sys.stderr,
                    )
            fam_cid = cid
            fam_members = []
            fam_max_blocks = 0

        fam_members.append((nid, blk, is_excl))
        if blk > fam_max_blocks:
            fam_max_blocks = blk

    # Finalize last family
    if fam_cid >= 0:
        _finalize_clone_family(fam_cid, fam_members, fam_max_blocks)
        families_processed += 1

    print(
        f"[freeable] clone pass done: {families_processed:,} families in "
        f"{time.time()-t4:.1f}s",
        file=sys.stderr,
    )

    # ------------------------------------------------------------------
    # Step 5: Hardlink family pass (streaming by dev,ino ordered)
    # Files with clone_id are excluded from hardlink grouping.
    # ------------------------------------------------------------------
    print("[freeable] streaming hardlink families...", file=sys.stderr)
    t5 = time.time()

    try:
        hl_cur = con.execute(
            "SELECT dev, ino, id, nlinks, size_blocks "
            "FROM files "
            "WHERE is_dir=0 AND clone_id IS NULL AND nlinks > 1 "
            "ORDER BY dev, ino"
        )
    except Exception as e:
        print(f"[freeable] hardlink query error: {e}", file=sys.stderr)
        hl_cur = iter([])

    hl_dev: int = -1
    hl_ino: int = -1
    hl_members: list = []   # list of (node_id, nlinks, size_blocks)

    def _finalize_hl_family(members: list) -> None:
        if not members:
            return
        nlinks = members[0][1]
        if len(members) < nlinks:
            # External links -- conservative: skip (credit 0)
            return
        # All in DB: credit once at LCA
        credit = members[0][2]
        running_lca = -1
        member_ids: list[int] = []
        for (nid, nl, blk) in members:
            if nid > max_id or depth_arr[nid] < 0:
                return
            member_ids.append(nid)
            if running_lca < 0:
                running_lca = nid
            else:
                running_lca = _lca_arr(running_lca, nid, depth_arr, parent_arr, max_id)
                if running_lca < 0:
                    return

        if running_lca < 0:
            return

        credit_arr[running_lca] += credit

        child_set: set = set()
        for nid in member_ids:
            if nid == running_lca:
                child_set.add(running_lca)
            else:
                dc = _direct_child_of_arr(running_lca, nid, parent_arr)
                child_set.add(dc)
        if len(child_set) >= 2:
            locked_contrib.append((running_lca, credit, child_set))

    for row in hl_cur:
        dev = row[0]
        ino = row[1]
        nid = row[2]
        nlinks = row[3]
        blk = row[4]

        if dev != hl_dev or ino != hl_ino:
            _finalize_hl_family(hl_members)
            hl_dev = dev
            hl_ino = ino
            hl_members = []

        hl_members.append((nid, nlinks, blk))

    _finalize_hl_family(hl_members)
    print(
        f"[freeable] hardlink pass done in {time.time()-t5:.1f}s", file=sys.stderr
    )

    # ------------------------------------------------------------------
    # Step 6: Singleton pass -- streaming via SQL (never builds a Python set)
    # Uses the temp table multi_cids to exclude multi-member clone families.
    # nlinks=1 files not in multi_cids get credited to their parent.
    # ------------------------------------------------------------------
    print("[freeable] streaming singleton pass...", file=sys.stderr)
    t6 = time.time()

    try:
        sing_cur = con.execute(
            "SELECT parent_id, size_blocks FROM files "
            "WHERE is_dir=0 AND nlinks=1 "
            "AND (clone_id IS NULL OR clone_id NOT IN (SELECT clone_id FROM multi_cids))"
        )
        for row in sing_cur:
            pid = row[0]
            blk = row[1]
            if pid is None:
                continue
            if 0 < pid <= max_id:
                credit_arr[pid] += blk
    except Exception as e:
        print(f"[freeable] singleton query error: {e}", file=sys.stderr)

    print(
        f"[freeable] singleton pass done in {time.time()-t6:.1f}s", file=sys.stderr
    )

    # ------------------------------------------------------------------
    # Step 7: Excluded subtree residual credits
    # residual[excl_id] = max(0, excl_blocks - sum(ef.blocks_sum for ef in this excl_id))
    # Credited to the excluded node itself (treated as leaf in bottom-up pass).
    # ------------------------------------------------------------------
    print("[freeable] computing excluded residuals...", file=sys.stderr)
    for nid in range(1, max_id + 1):
        if is_dir_arr[nid] == 2:  # excluded dir
            total_ef = excl_ef_total.get(nid, 0)
            residual = excl_blocks_arr[nid] - total_ef
            if residual > 0:
                credit_arr[nid] += residual

    # ------------------------------------------------------------------
    # Step 8: Bottom-up subtree accumulation via depth buckets
    # ------------------------------------------------------------------
    print("[freeable] bottom-up accumulation via depth buckets...", file=sys.stderr)
    t8 = time.time()

    # Find max depth
    max_depth = 0
    for nid in range(1, max_id + 1):
        d = depth_arr[nid]
        if d > max_depth:
            max_depth = d

    # Build depth buckets: bucket[d] = list of node_ids at depth d
    buckets: list[list[int]] = [[] for _ in range(max_depth + 1)]
    for nid in range(1, max_id + 1):
        d = depth_arr[nid]
        if d >= 0:
            buckets[d].append(nid)

    # subtree_arr[nid] = accumulated subtree freeable (not counting own credit)
    # Propagate bottom-up: parent's subtree += child's (credit + subtree)
    subtree_arr = array.array('q', [0] * (max_id + 1))

    # Process deepest levels first
    for d in range(max_depth, -1, -1):
        for nid in buckets[d]:
            isd = is_dir_arr[nid]
            if isd == 1:  # regular dir (not excluded)
                # propagate to parent
                pid = parent_arr[nid]
                if 0 < pid <= max_id:
                    subtree_arr[pid] += credit_arr[nid] + subtree_arr[nid]
            elif isd == 2:  # excluded dir (leaf aggregate)
                # propagate credit to parent (no subtree from inside)
                pid = parent_arr[nid]
                if 0 < pid <= max_id:
                    subtree_arr[pid] += credit_arr[nid]
            # files (isd==0): credits were already placed on parent_id in earlier steps;
            # nothing to propagate from the file node itself

    print(
        f"[freeable] bottom-up done in {time.time()-t8:.1f}s", file=sys.stderr
    )

    # ------------------------------------------------------------------
    # Step 9: Materialise freeable and locked_here dicts (non-zero only)
    # ------------------------------------------------------------------
    print("[freeable] materialising result dicts...", file=sys.stderr)
    freeable: dict[int, int] = {}
    for nid in range(1, max_id + 1):
        if is_dir_arr[nid] > 0:  # dir or excluded dir
            val = credit_arr[nid] + subtree_arr[nid]
            if val:
                freeable[nid] = val

    # locked_here: resolve child_set -> direct children of lca_node
    locked_here_d: dict[int, int] = collections.defaultdict(int)
    for (lca_node, credit, child_set) in locked_contrib:
        direct_children_of_lca: set = set()
        for cs in child_set:
            if cs == lca_node:
                continue
            if 0 < cs <= max_id and parent_arr[cs] == lca_node:
                direct_children_of_lca.add(cs)
            else:
                # Walk up to direct child of lca_node
                cur = cs
                while 0 < cur <= max_id:
                    p = parent_arr[cur]
                    if p < 0 or p == lca_node:
                        direct_children_of_lca.add(cur)
                        break
                    cur = p
        if len(direct_children_of_lca) >= 2:
            locked_here_d[lca_node] += credit

    locked_here = dict(locked_here_d)

    elapsed = time.time() - t0
    print(
        f"[freeable] done in {elapsed:.1f}s, {len(freeable):,} dirs with freeable>0",
        file=sys.stderr,
    )

    # Persist cache
    if scan_id is not None:
        _persist_freeable_cache(DB_PATH, scan_id, freeable, locked_here)

    return freeable, locked_here

